# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/prt_cashback"

# JWT
JWT_SECRET="troque_por_uma_chave_secreta_forte_aqui"
JWT_EXPIRES_IN="8h"

# App
PORT=3000
NODE_ENV=development

# AWS Rekognition — 1:1 face comparison (leave blank to use pixel-similarity fallback)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# Supabase Storage — selfie storage (thumb + full)
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
# Bucket name (create manually in Supabase Dashboard → Storage, set to private)
SUPABASE_STORAGE_BUCKET=selfies

STATION_NAME="Posto XYZ"
MIN_REDEMPTION_AMOUNT=10.00
MAX_DAILY_REDEMPTION=500.00
REDEMPTION_COOLDOWN_MINUTES=5
