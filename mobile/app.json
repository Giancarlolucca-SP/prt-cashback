{
  "expo": {
    "name": "PRT Cashback",
    "slug": "prt-cashback",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e3a5f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.prt.cashback",
      "associatedDomains": ["applinks:prtcashback.app"]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e3a5f"
      },
      "package": "com.prt.cashback",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            { "scheme": "https", "host": "prtcashback.app" },
            { "scheme": "prtcashback" },
            { "scheme": "prt-cashback" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID para acessar sua conta"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir que o PRT Cashback acesse a câmera para ler QR codes."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1e3a5f",
          "defaultChannel": "default",
          "androidStatusBar": {
            "backgroundColor": "#1e3a5f"
          }
        }
      ],
      "expo-font"
    ],
    "notification": {
      "icon": "./assets/icon.png",
      "color": "#1e3a5f",
      "androidMode": "default",
      "androidCollapsedTitle": "PRT Cashback"
    },
    "scheme": "prt-cashback",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "http://192.168.15.10:3000",
      "router": {},
      "eas": {
        "projectId": "f5706ced-7aee-4524-822e-4c0dfd7470df"
      }
    }
  }
}
