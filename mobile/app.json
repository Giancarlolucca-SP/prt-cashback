{
  "expo": {
    "name": "PostoCash",
    "slug": "postocash",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B00"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.postocash.app",
      "associatedDomains": [
        "applinks:postocash.app"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF6B00"
      },
      "package": "com.postocash.app",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "https",
              "host": "postocash.app"
            },
            {
              "scheme": "postocash"
            },
            {
              "scheme": "postocash"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID para acessar sua conta"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir que o PostoCash acesse a câmera para ler QR codes."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1e3a5f",
          "defaultChannel": "default",
          "androidStatusBar": {
            "backgroundColor": "#1e3a5f"
          }
        }
      ],
      "expo-font"
    ],
    "notification": {
      "icon": "./assets/icon.png",
      "color": "#1e3a5f",
      "androidMode": "default",
      "androidCollapsedTitle": "PostoCash"
    },
    "scheme": "postocash",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "http://192.168.15.10:3000",
      "router": {},
      "eas": {
        "projectId": "d4dfb95f-dd47-4912-b248-db2a50bce0d0"
      }
    },
    "owner": "tgrtech"
  }
}
